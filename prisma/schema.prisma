// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  role      String   @default("CLIENT")
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  documents   Document[]
  submissions TaxSubmission[]
  messages    Message[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String?
  content   String?  @db.Text
  imageUrl  String?
  priority  String   @default("normal")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaxSubmission {
  id            String  @id @default(cuid())
  userId        String // Sera lié au clerkId ou id du User
  firstName     String
  lastName      String
  taxYear       Int
  serviceType   String
  hasSpouse     Boolean @default(false)
  hasDependents Boolean @default(false)
  phone         String
  email         String?
  notes         String? @db.Text
  status        String  @default("En attente")
  // Valeurs : "En attente", "Acceptée", "En cours", "Terminé", "Annulé"

  createdAt DateTime  @default(now())
  messages  Message[]

  // Relation formelle avec User (très important pour l'intégrité)
  user User @relation(fields: [userId], references: [clerkId])
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  clientId  String? // L'ID Clerk de l'utilisateur
  isGeneral Boolean  @default(false)
  createdAt DateTime @default(now())

  clerkId String
  user    User?  @relation(fields: [clientId], references: [clerkId])
}

model Message {
  id           String         @id @default(cuid())
  text         String
  isRead       Boolean        @default(false)
  createdAt    DateTime       @default(now())
  senderId     String
  userId       String
  user         User           @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  submissionId String?
  submission   TaxSubmission? @relation(fields: [submissionId], references: [id])

  @@index([userId])
  @@index([submissionId])
}
